# Copy to .env and edit. The keyless mock backend is the default and needs none
# of these — they only matter for real-model runs (`make eval-real`).

# Backend: mock | anthropic | ollama
LLM_PROVIDER=mock

# Model id. Defaults per provider:
#   anthropic -> claude-opus-4-8     (also: claude-sonnet-4-6, claude-haiku-4-5)
#   ollama    -> llama3.1            (planned; not yet implemented)
#   mock      -> mock
# LLM_MODEL=claude-opus-4-8

# Required only when LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Agent orchestration knobs (sensible defaults applied if unset)
# AGENT_MAX_STEPS=8
# SQL_MAX_ROWS=1000
