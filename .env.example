# Copy to .env (gitignored) and fill in your key. config.py loads .env automatically.

# Required: your Anthropic API key.
ANTHROPIC_API_KEY=sk-ant-...

# Backend: anthropic (default) | ollama (roadmap)
# LLM_PROVIDER=anthropic

# Model id. Default: claude-opus-4-8. Cheaper: claude-sonnet-4-6, claude-haiku-4-5.
# LLM_MODEL=claude-opus-4-8

# Agent orchestration knobs (sensible defaults applied if unset)
# AGENT_MAX_STEPS=10
# SQL_MAX_ROWS=1000
