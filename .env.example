# Optional. Copy to .env (gitignored); config.py loads it automatically.
# No API key is needed — the Claude backend uses your local `claude` CLI login.

# Model id. Default: claude-opus-4-8. Cheaper: claude-sonnet-4-6, claude-haiku-4-5.
# LLM_MODEL=claude-opus-4-8

# Backend: anthropic (default, via the claude CLI) | ollama (roadmap)
# LLM_PROVIDER=anthropic

# Agent orchestration knobs (sensible defaults applied if unset)
# AGENT_MAX_STEPS=10
# SQL_MAX_ROWS=1000
